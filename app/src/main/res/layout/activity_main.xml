<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvAccueil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accueil OpenMinds"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/couleur_navy"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnNouvelleFormation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnNouvelleFormation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ Créer une formation"
        android:backgroundTint="@color/vert"
        android:textColor="@color/blanc"
        android:textAllCaps="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnStatistiques"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Statistiques admin"
        android:backgroundTint="@color/couleur_navy"
        android:textColor="@color/blanc"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnNouvelleFormation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnChoisirSession"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choisir une session"
        android:backgroundTint="@color/vert"
        android:textColor="@color/blanc"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnStatistiques"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>