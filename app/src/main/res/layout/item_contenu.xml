<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <!-- Le ConstraintLayout permet d'aligner parfaitement les 3 blocs (Icône - Textes - Flèche) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 1. L'ICÔNE DU MODULE (À gauche) -->
        <ImageView
            android:id="@+id/iv_module_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#F0F0F0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <!-- Note : J'ai mis un fond gris temporaire. Tu pourras utiliser 'android:src="@drawable/ton_icone"' plus tard -->

        <!-- 2. LES TEXTES (Au centre) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_module_icon"
            app:layout_constraintEnd_toStartOf="@id/tv_module_arrow">

            <TextView
                android:id="@+id/tv_module_numero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Module 1"
                android:textColor="#1C385C"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_module_titre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Les dangers de l'autoroute"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 3. LA FLÈCHE (À droite) -->
        <!-- J'utilise un TextView avec le symbole ">" pour que ça marche direct sans erreur de ressource manquante -->
        <TextView
            android:id="@+id/tv_module_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textSize="24sp"
            android:textColor="#1C385C"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>