<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER BLEU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F2744"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_logo_gradient"
                android:layout_marginEnd="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Open" android:textSize="16sp" android:textStyle="bold" android:textColor="#EEF2F8"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Minds" android:textSize="16sp" android:textStyle="bold" android:textColor="#1ECFB8"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tabs_container_light"
            android:padding="3dp">

            <TextView
                android:id="@+id/tabConnexion"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Connexion"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#7B8FA8"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabInscription"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Inscription"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#EEF2F8"
                android:background="@drawable/bg_tab_active_light"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CORPS BLANC -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Créer un compte" android:textSize="20sp" android:textStyle="bold" android:textColor="#111827" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rejoignez OpenMinds et commencez votre parcours citoyen." android:textSize="13sp" android:textColor="#6B7280" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="20dp"/>

            <!-- Prénom / Nom -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRÉNOM" android:textSize="10sp" android:textStyle="bold" android:textColor="#6B7280" android:letterSpacing="0.08" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etPrenom" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Marie" android:textColorHint="#9CA3AF" android:textColor="#111827" android:textSize="14sp" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_field_light" android:singleLine="true"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NOM" android:textSize="10sp" android:textStyle="bold" android:textColor="#6B7280" android:letterSpacing="0.08" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etNom" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Dupont" android:textColorHint="#9CA3AF" android:textColor="#111827" android:textSize="14sp" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_field_light" android:singleLine="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Email -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ADRESSE EMAIL" android:textSize="10sp" android:textStyle="bold" android:textColor="#6B7280" android:letterSpacing="0.08" android:layout_marginBottom="6dp"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="14dp">
                <EditText android:id="@+id/etEmailInscription" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="email@exemple.fr" android:textColorHint="#9CA3AF" android:textColor="#111827" android:textSize="14sp" android:inputType="textEmailAddress" android:paddingStart="44dp" android:paddingEnd="14dp" android:background="@drawable/bg_input_field_light" android:singleLine="true"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:layout_marginStart="14dp" android:src="@drawable/ic_email" android:alpha="0.4"/>
            </FrameLayout>

            <!-- Mot de passe -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOT DE PASSE" android:textSize="10sp" android:textStyle="bold" android:textColor="#6B7280" android:letterSpacing="0.08" android:layout_marginBottom="6dp"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="6dp">
                <EditText android:id="@+id/etPasswordInscription" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Minimum 6 caractères" android:textColorHint="#9CA3AF" android:textColor="#111827" android:textSize="14sp" android:inputType="textPassword" android:paddingStart="44dp" android:paddingEnd="14dp" android:background="@drawable/bg_input_field_light" android:singleLine="true"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:layout_marginStart="14dp" android:src="@drawable/ic_lock" android:alpha="0.4"/>

            </FrameLayout>

            <!-- Barre de force -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="3dp" android:orientation="horizontal" android:layout_marginBottom="14dp">
                <View android:id="@+id/seg1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E5E7EB"/>
                <View android:id="@+id/seg2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E5E7EB"/>
                <View android:id="@+id/seg3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E5E7EB"/>
                <View android:id="@+id/seg4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#E5E7EB"/>
            </LinearLayout>

            <!-- Confirmer mot de passe -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONFIRMER LE MOT DE PASSE" android:textSize="10sp" android:textStyle="bold" android:textColor="#6B7280" android:letterSpacing="0.08" android:layout_marginBottom="6dp"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="16dp">
                <EditText android:id="@+id/etConfirmPassword" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Répétez le mot de passe" android:textColorHint="#9CA3AF" android:textColor="#111827" android:textSize="14sp" android:inputType="textPassword" android:paddingStart="44dp" android:paddingEnd="14dp" android:background="@drawable/bg_input_field_light" android:singleLine="true"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:layout_marginStart="14dp" android:src="@drawable/ic_lock" android:alpha="0.4"/>

            </FrameLayout>

            <!-- CGU -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="top" android:layout_marginBottom="20dp">
                <CheckBox android:id="@+id/cbCgu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="#1ECFB8" android:layout_marginEnd="8dp" android:layout_marginTop="2dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J'accepte les conditions d'utilisation et la politique de confidentialité d'OpenMinds." android:textSize="12sp" android:textColor="#6B7280" android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnCreerCompte"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Créer mon compte"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:backgroundTint="@color/vert"
                android:layout_marginBottom="16dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Déjà un compte ? " android:textSize="13sp" android:textColor="#6B7280"/>
                <TextView android:id="@+id/tvAllerConnexion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Se connecter" android:textSize="13sp" android:textColor="#0AAEA0" android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>