<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER BLEU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F2744"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_logo_gradient"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#EEF2F8"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minds"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1ECFB8"/>
        </LinearLayout>

        <!-- Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tabs_container_light"
            android:padding="3dp">

            <TextView
                android:id="@+id/tabConnexion"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Connexion"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#EEF2F8"
                android:background="@drawable/bg_tab_active_light"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabInscription"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Inscription"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#7B8FA8"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CORPS BLANC -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bon retour !"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connectez-vous pour reprendre votre parcours de formation."
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="24dp"/>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADRESSE EMAIL"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="benevole@exemple.fr"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:inputType="textEmailAddress"
                    android:paddingStart="44dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field_light"
                    android:singleLine="true"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_email"
                    android:alpha="0.4"/>
            </FrameLayout>

            <!-- Mot de passe -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOT DE PASSE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="••••••••"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:inputType="textPassword"
                    android:paddingStart="44dp"
                    android:paddingEnd="44dp"
                    android:background="@drawable/bg_input_field_light"
                    android:singleLine="true"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_lock"
                    android:alpha="0.4"/>

                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_visibility"
                    android:alpha="0.4"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvMotDePasseOublie"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginBottom="20dp"
                android:text="Mot de passe oublié ?"
                android:textSize="12sp"
                android:textColor="#0AAEA0"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <Button
                android:id="@+id/btnConnexion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Se connecter"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/bg_bouton_gradient"
                android:layout_marginBottom="16dp"/>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E5E7EB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ou" android:textSize="12sp" android:textColor="#9CA3AF" android:paddingStart="12dp" android:paddingEnd="12dp"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E5E7EB"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Continuer avec Google"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:textAllCaps="false"
                android:background="@drawable/bg_bouton_outline_light"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pas encore de compte ? " android:textSize="13sp" android:textColor="#6B7280"/>
                <TextView
                    android:id="@+id/tvAllerInscription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S'inscrire"
                    android:textSize="13sp"
                    android:textColor="#0AAEA0"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
