<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivSession"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNomSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En Ligne"
                    android:textColor="#1A2B4A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDateSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 mars 2026 – 09h – 10h"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPlacesSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 20 places disponibles"
                    android:textColor="#2ECC71"
                    android:textSize="12sp" />
            </LinearLayout>

            <RadioButton
                android:id="@+id/radioSession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvLieuBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🖥 En ligne"
                android:background="@drawable/badge_gris"
                android:textSize="11sp"
                android:textColor="#444444"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvDureeBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🕐 1h"
                android:background="@drawable/badge_gris"
                android:textSize="11sp"
                android:textColor="#444444"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvMaxBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👥 20 max"
                android:background="@drawable/badge_gris"
                android:textSize="11sp"
                android:textColor="#444444"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>