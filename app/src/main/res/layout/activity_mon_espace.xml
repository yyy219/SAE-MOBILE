<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER BLEU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F2744"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <!-- Topbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnRetour"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_icon_btn_light"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mon espace"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#EEF2F8"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/btnParametres"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/bg_icon_btn_light"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Profil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1ECFB8"
                android:gravity="center"
                android:background="@drawable/bg_avatar_light"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNomPrenom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chargement..."
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#EEF2F8"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#7B8FA8"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvNiveau"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1ECFB8"
                android:background="@drawable/bg_niveau_pill_light"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CORPS SCROLLABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vue d'ensemble (commune admin + bénévole) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vue d'ensemble"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="22dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvNbFormations" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="22sp" android:textStyle="bold" android:textColor="#0AAEA0" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Formations" android:textSize="10sp" android:textColor="#6B7280" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvNbBadges" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="22sp" android:textStyle="bold" android:textColor="#3A80F0" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Badges" android:textSize="10sp" android:textColor="#6B7280" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvTauxReussite" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="22sp" android:textStyle="bold" android:textColor="#D97706" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Réussite" android:textSize="10sp" android:textColor="#6B7280" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════════ -->
            <!-- SECTION ADMIN (visible si role = admin)   -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/sectionAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actions administrateur"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="10dp"/>

                <!-- Bouton créer formation -->
                <LinearLayout
                    android:id="@+id/btnAdminCreerFormation"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:background="@drawable/bg_surface_card_light"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+ Créer une formation" android:textSize="14sp" android:textStyle="bold" android:textColor="#0AAEA0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Bouton statistiques -->
                <LinearLayout
                    android:id="@+id/btnAdminStatistiques"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:background="@drawable/bg_surface_card_light"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Statistiques admin" android:textSize="14sp" android:textStyle="bold" android:textColor="#3A80F0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Bouton gérer sessions -->
                <LinearLayout
                    android:id="@+id/btnAdminSessions"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:background="@drawable/bg_surface_card_light"
                    android:layout_marginBottom="22dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Gérer les sessions" android:textSize="14sp" android:textStyle="bold" android:textColor="#D97706"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Bouton déconnexion admin -->
                <LinearLayout
                    android:id="@+id/btnDeconnexionAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_bouton_outline_light"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Se déconnecter" android:textSize="14sp" android:textStyle="bold" android:textColor="#EF4444"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════ -->
            <!-- SECTION BÉNÉVOLE (visible si role = benevole) -->
            <!-- ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/sectionBenevole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Formations en cours -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Formations en cours" android:textSize="13sp" android:textStyle="bold" android:textColor="#111827"/>
                    <TextView android:id="@+id/btnBenevoleVoirCatalogue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voir tout" android:textSize="11sp" android:textColor="#0AAEA0" android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <!-- Carte formation 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_surface_card_light" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Environnement" android:textSize="10sp" android:textColor="#0A7A6E" android:background="@drawable/bg_chip_env_light" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="En ligne" android:textSize="10sp" android:textColor="#6B7280" android:background="@drawable/bg_chip_muted_light" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Formation à l'écologie" android:textSize="13sp" android:textStyle="bold" android:textColor="#111827" android:layout_marginBottom="2dp" android:id="@+id/tvTitreFormation1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Module 2 sur 3 · En ligne · 15 min" android:textSize="11sp" android:textColor="#6B7280" android:id="@+id/tvSousInfoFormation1"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tvPct1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="66%" android:textSize="13sp" android:textStyle="bold" android:textColor="#0AAEA0" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progressFormation1" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progress="66" android:max="100" android:background="@drawable/bg_progress_track_light" android:progressDrawable="@drawable/bg_progress_fill"/>
                </LinearLayout>

                <!-- Carte formation 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_surface_card_light" android:layout_marginBottom="18dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inclusion" android:textSize="10sp" android:textColor="#1D4ED8" android:background="@drawable/bg_chip_inc_light" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Présentiel" android:textSize="10sp" android:textColor="#6B7280" android:background="@drawable/bg_chip_muted_light" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Introduction à l'inclusion" android:textSize="13sp" android:textStyle="bold" android:textColor="#111827" android:layout_marginBottom="2dp" android:id="@+id/tvTitreFormation2"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Module 1 sur 2 · Présentiel · 30 min" android:textSize="11sp" android:textColor="#6B7280" android:id="@+id/tvSousInfoFormation2"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tvPct2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40%" android:textSize="13sp" android:textStyle="bold" android:textColor="#0AAEA0" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progressFormation2" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:progress="40" android:max="100" android:background="@drawable/bg_progress_track_light" android:progressDrawable="@drawable/bg_progress_fill"/>
                </LinearLayout>

                <!-- Bouton choisir session -->
                <LinearLayout
                    android:id="@+id/btnBenevoleChoisirSession"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:background="@drawable/bg_surface_card_light"
                    android:layout_marginBottom="22dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Choisir une session" android:textSize="14sp" android:textStyle="bold" android:textColor="#3A80F0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Badges -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mes badges" android:textSize="13sp" android:textStyle="bold" android:textColor="#111827"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textSize="24sp" android:textColor="#0AAEA0" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Éco-citoyen" android:textSize="10sp" android:textStyle="bold" android:textColor="#111827" android:gravity="center" android:layout_marginBottom="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 mars 2026" android:textSize="9sp" android:textColor="#9CA3AF" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textSize="24sp" android:textColor="#3A80F0" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inclusif" android:textSize="10sp" android:textStyle="bold" android:textColor="#111827" android:gravity="center" android:layout_marginBottom="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 fév. 2026" android:textSize="9sp" android:textColor="#9CA3AF" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_surface_card_light" android:layout_marginStart="4dp" android:alpha="0.4">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="20sp" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Citoyen+" android:textSize="10sp" android:textColor="#9CA3AF" android:gravity="center" android:layout_marginBottom="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Verrouillé" android:textSize="9sp" android:textColor="#9CA3AF" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Bouton déconnexion bénévole -->
                <LinearLayout
                    android:id="@+id/btnDeconnexionBenevole"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_bouton_outline_light"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Se déconnecter" android:textSize="14sp" android:textStyle="bold" android:textColor="#EF4444"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_navbar_light">

        <LinearLayout android:id="@+id/navAccueil" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌂" android:textSize="18sp" android:textColor="#9CA3AF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Accueil" android:textSize="9sp" android:textColor="#9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navCatalogue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊞" android:textSize="18sp" android:textColor="#9CA3AF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Catalogue" android:textSize="9sp" android:textColor="#9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navMonEspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☺" android:textSize="18sp" android:textColor="#0AAEA0"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon espace" android:textSize="9sp" android:textColor="#0AAEA0" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnOuvrirBadges" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textSize="18sp" android:textColor="#9CA3AF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Badges" android:textSize="9sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>